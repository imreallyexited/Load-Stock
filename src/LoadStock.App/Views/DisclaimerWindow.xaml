<Window x:Class="LoadStock.App.Views.DisclaimerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LoadStock — Kullanım Koşulları" Height="440" Width="560"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Bg}"
        TextElement.Foreground="{StaticResource Text}"
        FontFamily="Segoe UI" FontSize="13"
        ResizeMode="NoResize" ShowInTaskbar="True">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Başlamadan önce" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>

        <Border Grid.Row="1" Background="{StaticResource Panel}" BorderBrush="{StaticResource BorderC}" BorderThickness="1" CornerRadius="6" Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,10"
                               Text="LoadStock gayriresmî bir araçtır ve Inditex, Zara, Bershka ya da Stradivarius ile herhangi bir bağlantısı yoktur."/>
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,10"
                               Text="Stok bilgisini, mağazaların web sitelerinin kendi kullandığı iç servislerden okur. Bu servisler belgelenmemiştir; herhangi bir zamanda değişebilir veya çalışmayı durdurabilir."/>
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,10"
                               Text="Çok sık sorgulama, sitelerin bot korumasını tetikleyebilir ve internet bağlantınızın (IP adresinizin) ilgili siteden geçici olarak engellenmesine yol açabilir. Bu nedenle uygulama kibar aralıklarla sorgular ve yalnızca kişisel, düşük hacimli kullanım için tasarlanmıştır."/>
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,10"
                               Text="Bu araç bu sitelerin kullanım koşullarına aykırı olabilir. Aldığınız verileri yeniden dağıtmayın. Uygulama hiçbir garanti vermez; tüm sorumluluk kullanıcıya aittir."/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <CheckBox Grid.Row="2" x:Name="AcceptCheck" Margin="2,14,0,0"
                  Content="Okudum, anladım ve kabul ediyorum." Checked="Accept_Toggled" Unchecked="Accept_Toggled"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Vazgeç ve çık" Style="{StaticResource Subtle}" Click="Decline_Click" Margin="0,0,8,0"/>
            <Button x:Name="AcceptButton" Content="Kabul et ve başla" Style="{StaticResource Primary}" IsEnabled="False" Click="Accept_Click"/>
        </StackPanel>
    </Grid>
</Window>
