<Window x:Class="LoadStock.App.Views.AddProductDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ürün Ekle" Height="520" Width="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Bg}"
        TextElement.Foreground="{StaticResource Text}"
        FontFamily="Segoe UI" FontSize="13"
        ResizeMode="NoResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Ürün linkini yapıştır" FontWeight="SemiBold"/>
            <TextBlock Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,2,0,8"
                       Text="Zara, Bershka veya Stradivarius (Türkiye) ürün sayfasının adresini yapıştırın."/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}" Padding="6,5" VerticalContentAlignment="Center"/>
                <Button Grid.Column="1" Content="Getir" Style="{StaticResource Primary}" Margin="8,0,0,0"
                        Command="{Binding FetchCommand}"/>
            </Grid>
        </StackPanel>

        <TextBlock Grid.Row="1" Text="{Binding Error}" Foreground="#DC2626" TextWrapping="Wrap" Margin="0,8,0,0"
                   Visibility="{Binding Error, Converter={StaticResource NullToCollapsed}}"/>

        <StackPanel Grid.Row="2" Margin="0,12,0,0" Visibility="{Binding Loaded, Converter={StaticResource BoolToVisible}}">
            <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold" FontSize="15" TextWrapping="Wrap"/>
            <CheckBox Content="Tüm bedenleri izle (herhangi biri stoğa girince bildir)" IsChecked="{Binding WatchAnySize}" Margin="0,10,0,0"/>
            <TextBlock Text="veya yalnızca seçtiğin bedenler:" Foreground="{StaticResource Muted}" Margin="0,8,0,0"/>
        </StackPanel>

        <Border Grid.Row="3" Margin="0,8,0,0" Background="{StaticResource Panel}" BorderBrush="{StaticResource BorderC}" BorderThickness="1" CornerRadius="6"
                Visibility="{Binding Loaded, Converter={StaticResource BoolToVisible}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Sizes}" IsEnabled="{Binding SpecificSizes}" Margin="10">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Display}" IsChecked="{Binding Selected}" Margin="0,4"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="İptal" Style="{StaticResource Subtle}" Click="Cancel_Click" Margin="0,0,8,0"/>
            <Button Content="Kaydet" Style="{StaticResource Primary}" Click="Save_Click"
                    Visibility="{Binding Loaded, Converter={StaticResource BoolToVisible}}"/>
        </StackPanel>
    </Grid>
</Window>
