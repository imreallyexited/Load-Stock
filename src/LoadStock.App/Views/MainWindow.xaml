<Window x:Class="LoadStock.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LoadStock" Height="600" Width="940"
        MinHeight="460" MinWidth="760"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Bg}"
        TextElement.Foreground="{StaticResource Text}"
        FontFamily="Segoe UI" FontSize="13"
        Icon="pack://application:,,,/Assets/tray.ico">
    <DockPanel>
        <!-- Üst çubuk -->
        <Border DockPanel.Dock="Top" Background="{StaticResource Panel}" BorderBrush="{StaticResource BorderC}" BorderThickness="0,0,0,1">
            <Grid Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="LoadStock" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource Muted}" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Tümünü Yenile" Style="{StaticResource Primary}"
                        Background="#374151" Command="{Binding RefreshAllCommand}" IsEnabled="{Binding NotBusy}"
                        Margin="0,0,8,0" VerticalAlignment="Center"/>
                <Button Grid.Column="2" Content="+ Ürün Ekle" Style="{StaticResource Primary}"
                        Click="AddProduct_Click" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <TabControl Margin="12" Background="Transparent" BorderThickness="0">
            <!-- TAKİP -->
            <TabItem Header="Takip">
                <DataGrid ItemsSource="{Binding Tracked}" AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowHeight="40"
                          Background="{StaticResource Panel}" BorderBrush="{StaticResource BorderC}"
                          CanUserAddRows="False" SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Marka" Binding="{Binding Brand}" Width="90"/>
                        <DataGridTextColumn Header="Ürün" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Renk" Binding="{Binding Color}" Width="120"/>
                        <DataGridTextColumn Header="İzlenen" Binding="{Binding Watch}" Width="110"/>
                        <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="150"/>
                        <DataGridTextColumn Header="Son" Binding="{Binding LastChecked}" Width="60"/>
                        <DataGridTemplateColumn Header="" Width="230">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="Aç" Style="{StaticResource Subtle}"
                                                Command="{Binding DataContext.OpenCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="{Binding PauseLabel}" Style="{StaticResource Subtle}"
                                                Command="{Binding DataContext.TogglePauseCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="Kaldır" Style="{StaticResource Subtle}" Foreground="#DC2626"
                                                Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- GEÇMİŞ -->
            <TabItem Header="Geçmiş">
                <DataGrid ItemsSource="{Binding History}" AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowHeight="34"
                          Background="{StaticResource Panel}" BorderBrush="{StaticResource BorderC}"
                          CanUserAddRows="False" SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Zaman" Binding="{Binding When}" Width="130"/>
                        <DataGridTextColumn Header="Marka" Binding="{Binding Brand}" Width="90"/>
                        <DataGridTextColumn Header="Ürün" Binding="{Binding Product}" Width="*"/>
                        <DataGridTextColumn Header="Beden" Binding="{Binding Size}" Width="80"/>
                        <DataGridTextColumn Header="Fiyat" Binding="{Binding Price}" Width="90"/>
                        <DataGridTemplateColumn Header="" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Aç" Style="{StaticResource Subtle}"
                                            Command="{Binding DataContext.OpenHistoryCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- AYARLAR -->
            <TabItem Header="Ayarlar">
                <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource BorderC}" BorderThickness="1" CornerRadius="6">
                    <StackPanel Margin="20" MaxWidth="520" HorizontalAlignment="Left" DataContext="{Binding Settings}">
                        <TextBlock Text="Kontrol sıklığı" FontWeight="SemiBold"/>
                        <TextBlock Foreground="{StaticResource Muted}" TextWrapping="Wrap"
                                   Text="Her ürün ne sıklıkla kontrol edilsin. Daha sık = daha hızlı bildirim, ama ev IP'iniz için biraz daha yüksek ban riski."/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Slider Minimum="3" Maximum="30" Width="260" Value="{Binding IntervalMinutes}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding IntervalMinutes, StringFormat='{}{0} dakika'}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Slider Minimum="0" Maximum="180" Width="260" Value="{Binding JitterSeconds}" TickFrequency="10" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding JitterSeconds, StringFormat='±{0} sn rastgelelik'}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <CheckBox Content="Bildirim sesi" IsChecked="{Binding SoundEnabled}" Margin="0,18,0,0"/>
                        <CheckBox Content="Windows açılışında arkaplanda başlat" IsChecked="{Binding Autostart}" Margin="0,10,0,0"/>

                        <TextBlock Text="{Binding WebViewStatus}" Foreground="{StaticResource Muted}" Margin="0,18,0,0"/>

                        <Border Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,18,0,0">
                            <TextBlock TextWrapping="Wrap" Foreground="#9A3412"
                                       Text="Bu araç gayriresmîdir ve Inditex ile ilişkisi yoktur. Mağazaların kendi iç servislerini kullanır; bu servisler değişebilir ya da erişiminizi geçici olarak engelleyebilir. Kişisel ve düşük hacimli kullanım içindir."/>
                        </Border>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
